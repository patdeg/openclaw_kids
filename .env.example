# ============================================================
#  DANGER: This file contains SECRETS
#  NEVER commit this file. NEVER share it.
#  See README.md Stage 7 for the full explanation.
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#    chmod 600 .env
# ============================================================

# ── Channels ──────────────────────────────────────────────────

# Discord
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_USER_ID=

# WhatsApp: phone number allowed to chat (E.164 format)
WHATSAPP_ALLOWED_NUMBER=+1...

# ── School (Canvas LMS) ──────────────────────────────────────
# Find your Canvas URL: log into your school's Canvas, and the
# base URL is everything before /courses (e.g., https://myschool.instructure.com)

CANVAS_API_KEY=
CANVAS_BASE_URL=https://myschool.instructure.com/api/v1

# ── Minecraft Server ─────────────────────────────────────────
# The machine that runs your Minecraft servers (see Stage 16 in README).
# Set these to match your local network setup.

MINECRAFT_SSH_HOST=192.168.1.100
MINECRAFT_SSH_USER=minecraft
MINECRAFT_SERVER_DIR=/usr/local/games/minecraft_server

# ── School District ─────────────────────────────────────────
# Used by california-study skill for curriculum alignment

SCHOOL_DISTRICT=My School District

# ── Sports ──────────────────────────────────────────────────
# Used by volleyball-intel skill for "our club" in rankings/results

VOLLEYBALL_OUR_CLUB=My Club Name

# ── Printer ───────────────────────────────────────────────────

PRINTER_IP=192.168.1.200

# ── Email (Migadu or other IMAP provider) ────────────────────

# Personal email account (default himalaya account)
MIGADU_PASSWORD=

# Agent email account (optional — for inbound task creation and outbound notifications)
# Set AGENT_EMAIL to your assistant's email (e.g., mybot@yourdomain.com)
# and MIGADU_AGENT_PASSWORD to its password. The himalaya "agent" account uses these.
# Usage: himalaya -a agent envelope list
AGENT_EMAIL=
MIGADU_AGENT_PASSWORD=

# ── Family Email Allowlist ─────────────────────────────────────
# Comma-separated list of email addresses the agent is allowed to
# send to and receive from. This is a safety filter — the agent will
# ignore inbound emails from unknown senders and refuse to email
# anyone not on this list.
FAMILY_EMAILS=parent@example.com,sibling@example.com

# ── Web UI ────────────────────────────────────────────────────
# These go in web.env (separate file from gateway .env)

# WEB_PORT=8085
# WEB_PASSWORD=<openssl rand -base64 24>
# WEB_USERNAME=Player
# SESSION_SECRET=<openssl rand -hex 32>
