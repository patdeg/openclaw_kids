# OpenClaw Web Service — Secrets
# Copy to /opt/openclaw/alfred-web.env and fill in your values
# chmod 600 /opt/openclaw/alfred-web.env

# ── Web Port ──────────────────────────────────────────────────────────────────
ALFRED_WEB_PORT=8085
ALFRED_WEB_BASE_URL=https://your-pi-ip:8085

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: https://your-domain/auth/callback
# 3. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=123456789.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Access Control ────────────────────────────────────────────────────────────
# Only this Google account can log in
ALLOWED_EMAIL=you@gmail.com

# Session cookie encryption — generate with: openssl rand -hex 32
SESSION_SECRET=paste-your-64-char-hex-string-here

# ── Voice Pipeline (Demeterics) ───────────────────────────────────────────────
DEMETERICS_API_KEY=dmt_...
DEMETERICS_BASE_URL=https://api.demeterics.com

# ── Media Analysis (Groq) ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Web Search ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
