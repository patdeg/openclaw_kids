# OpenClaw Web Service — Secrets
# Copy to /opt/openclaw/web.env and fill in your values
# chmod 600 /opt/openclaw/web.env

# ── Web Port ──────────────────────────────────────────────────────────────────
WEB_PORT=8085

# ── Authentication ────────────────────────────────────────────────────────────
# Password to access the web UI. Must be at least 16 characters with
# uppercase, lowercase, digits, and special characters.
# Generate a strong one: openssl rand -base64 24
WEB_PASSWORD=

# Display name shown in the UI (optional, defaults to "Player")
WEB_USERNAME=

# Session cookie encryption — generate with: openssl rand -hex 32
SESSION_SECRET=paste-your-64-char-hex-string-here
